{
  "name": "cizzuk",
  "compatibility_date": "2026-04-10",
  "workers_dev": false,
  "assets": {
    "directory": "./_site",
    "not_found_handling": "404-page"
  },
  "build": {
    "command": "npm run build"
  },
  "routes": [
    {
      "pattern": "cizzuk.net",
      "custom_domain": true
    }
  ]
}